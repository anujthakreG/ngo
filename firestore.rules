rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // In a real production app, we'd check request.auth.token.email_verified == true
      // For this demo/setup, we'll stick to basic auth
      return isSignedIn();
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string &&
               data.role in ['restaurant', 'ngo'] &&
               data.displayName is string &&
               data.displayName.size() <= 100;
      }

      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'address', 'phone', 'role']);
    }

    // 2. Food Listings
    match /listings/{listingId} {
      function isValidListing(data) {
        return data.restaurantId is string &&
               data.foodType is string &&
               data.foodType.size() <= 100 &&
               data.status in ['available', 'claimed', 'completed'] &&
               data.quantity is string &&
               data.location is string &&
               data.maxPickupDays is number &&
               data.maxPickupDays >= 1 &&
               data.maxPickupDays <= 7;
      }

      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    incoming().restaurantId == request.auth.uid && 
                    isValidListing(incoming());
      
      allow update: if isSignedIn() && (
        // Restaurant owner updating their own listing
        (existing().restaurantId == request.auth.uid && isValidListing(incoming())) ||
        // NGO claiming a listing
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'claimedBy', 'ngoName', 'updatedAt']) &&
          existing().status == 'available' &&
          incoming().status == 'claimed' &&
          incoming().claimedBy == request.auth.uid
        ) ||
        // Restaurant marking as completed
        (
          existing().restaurantId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
          existing().status == 'claimed' &&
          incoming().status == 'completed'
        )
      );
      
      allow delete: if false; // Prefer soft deletes or status updates
    }
  }
}
